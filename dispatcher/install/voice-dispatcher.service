[Unit]
Description=voice-dispatcher — ambient voice control for claude-code-hermit
After=network.target sound.target

[Service]
Type=simple
# Set by install-linux.sh
ExecStart=VENV_PYTHON_PLACEHOLDER -m voice_dispatcher run
Restart=on-failure
RestartSec=5
# User session service — PipeWire/PulseAudio socket and XDG_RUNTIME_DIR are
# inherited from PAM on login.  No audio group or DISPLAY needed.

[Install]
WantedBy=default.target
