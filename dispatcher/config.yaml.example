# voice-dispatcher config  — copy to ~/.config/voice-dispatcher/config.yaml
# and edit before first run.

# ── Audio ──────────────────────────────────────────────────────────────────────

audio:
  # Input device: use the built-in mic, NOT AirPods.
  # AirPods force Bluetooth SCO codec (mono 8-16 kHz) when the mic is active,
  # which degrades Whisper accuracy significantly.
  # Leave null to use the system default.  Use `voice-dispatcher list-devices`
  # to find the index of your preferred mic.
  input_device: null    # e.g.  2  (integer index)
  output_device: null   # null = system default (AirPods for output is fine)

  # Capture rate is fixed at 16 kHz (Whisper's requirement); not configurable.

  # Silero VAD threshold — higher = less sensitive (fewer false positives)
  vad_threshold: 0.5

  # Play a short 40ms 600Hz click when VAD fires but no trigger matches.
  # Off by default.  Useful for debugging "is it even listening?" during setup.
  no_match_tick: false

# ── Whisper ────────────────────────────────────────────────────────────────────

whisper:
  model: "tiny"         # tiny | base | small
  device: "cpu"         # cpu | cuda
  compute_type: "int8"  # int8 | float16 | float32

# ── Agents ────────────────────────────────────────────────────────────────────
#
# Each agent maps a set of trigger phrases to a WebSocket token and a Piper
# voice file.  Run  voice-dispatcher config add-agent <id>  to register one.
#
# Adding an agent is a 3-step recipe (not just one YAML edit):
#   1.  voice-dispatcher config add-agent <id> --triggers "..." --voice <voice>
#   2.  claude plugin install voice@voice-channel --scope local  in that container
#   3.  /voice:configure  with the matching dispatcher URL and token

agents:
  jarvis:
    # Trigger phrases — fuzzy-matched (1-2 char edit distance), case-insensitive
    triggers:
      - "hey jarvis"
      - "jarvis"
      - "ó jarvis"
    language: en            # hint passed to Whisper; null = auto-detect
    voice: en_US-lessac-medium.onnx
    websocket_token: "REPLACE_WITH_TOKEN"
    # Relay Claude's tool-permission prompts through the voice channel.
    # OFF by default.  When true, the dispatcher TTSes a phonetic prompt
    # ("Bash needs permission. Say yes or no, followed by alpha bravo...") and
    # listens for a spoken verdict that must include the 5-letter request id.
    # SECURITY: the mic does not authenticate the speaker — a TV or housemate
    # could approve a tool call.  The local terminal dialog is always the
    # fallback.  Must ALSO be enabled plugin-side via /voice:configure.
    enable_permission_relay: false

  # Additional agents — uncomment and fill in:
  # casa:
  #   triggers:
  #     - "hey casa"
  #     - "casa"
  #     - "ó casa"
  #   language: pt
  #   voice: pt_PT-tugao-medium.onnx
  #   websocket_token: "REPLACE_WITH_TOKEN"

# ── Server ────────────────────────────────────────────────────────────────────

server:
  host: "0.0.0.0"     # LAN-reachable.  Change to a specific interface on multi-NIC laptops.
  port: 7355

# ── Piper voices ──────────────────────────────────────────────────────────────
#
# Place .onnx voice files (and matching .onnx.json files) under this directory.
# Download from: https://github.com/rhasspy/piper/releases

piper:
  voices_dir: "~/.local/share/voice-dispatcher/voices"
